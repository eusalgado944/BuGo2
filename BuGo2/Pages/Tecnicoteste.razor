@page "/tecnico"
@using Bugo_shared.Models
@using Bugo_shared.Enum
@inject HttpClient Http

<h3>Dashboard do Técnico</h3>

<p>Técnico: @nomeTecnico</p>

<hr />

<h4>📌 Chamados Abertos</h4>

@if (abertos == null)
{
    <p>Carregando...</p>
}
else if (abertos.Count == 0)
{
    <p>Nenhum chamado aberto.</p>
}
else
{
    @foreach (var c in abertos)
    {
        <div style="border:1px solid #ccc; padding:10px; margin:5px;">
            <b>@c.Titulo</b><br />
            @c.Descricao <br />
            Status: @c.Status <br />

            <button @onclick="() => Assumir(c.Id)">Assumir</button>
        </div>
    }
}

<hr />

<h4>🧑‍🔧 Meus Chamados</h4>

@if (meusChamados == null)
{
    <p>Carregando...</p>
}
else if (meusChamados.Count == 0)
{
    <p>Você não possui chamados atribuídos.</p>
}
else
{
    @foreach (var c in meusChamados)
    {
        <div style="border:1px solid green; padding:10px; margin:5px;">
            <b>@c.Titulo</b><br />
            @c.Descricao <br />
            Status: @c.Status <br />

            @if (c.Status != StatusChamado.Finalizado)
            {
                <button @onclick="() => Finalizar(c.Id)">Finalizar</button>
            }
        </div>
    }
}

@code {
    private string? nomeTecnico;
    private List<Chamado>? abertos;
    private List<Chamado>? meusChamados;

    protected override async Task OnInitializedAsync()
    {
        nomeTecnico = "Técnico 01"; // Aqui você pode obter do usuario/local storage
        await CarregarChamados();
    }

    private async Task CarregarChamados()
    {
        try
        {
            abertos = await Http.GetFromJsonAsync<List<Chamado>>("api/chamados/abertos") ?? new();
            meusChamados = await Http.GetFromJsonAsync<List<Chamado>>($"api/chamados/tecnico/{nomeTecnico}") ?? new();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Erro ao carregar chamados: {ex.Message}");
        }
    }

    private async Task Assumir(int id)
    {
        try
        {
            var response = await Http.PostAsJsonAsync($"api/chamados/{id}/assumir", new { tecnico = nomeTecnico });
            if (response.IsSuccessStatusCode)
            {
                await CarregarChamados();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Erro ao assumir chamado: {ex.Message}");
        }
    }

    private async Task Finalizar(int id)
    {
        try
        {
            var response = await Http.PostAsync($"api/chamados/{id}/finalizar", null);
            if (response.IsSuccessStatusCode)
            {
                await CarregarChamados();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Erro ao finalizar chamado: {ex.Message}");
        }
    }
}