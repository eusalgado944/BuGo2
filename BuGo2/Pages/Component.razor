@page "/chamados"
@using Bugo_shared.Models
@inject HttpClient Http
@inject IJSRuntime JS

<div class="container mt-5">
    <h2 class="mb-4">Gerenciar Chamados</h2>

    <!-- Seção de Criação -->
    <div class="card mb-5 shadow-sm">
        <div class="card-header bg-primary text-white">
            <h5 class="mb-0">📝 Novo Chamado</h5>
        </div>
        <div class="card-body">
            <form @onsubmit="Criar">
                <div class="mb-3">
                    <label for="titulo" class="form-label">Título</label>
                    <input 
                        type="text" 
                        class="form-control" 
                        id="titulo"
                        @bind="novo.Titulo" 
                        placeholder="Digite o título do chamado"
                        required />
                </div>
                <div class="mb-3">
                    <label for="descricao" class="form-label">Descrição</label>
                    <textarea 
                        class="form-control" 
                        id="descricao"
                        @bind="novo.Descricao" 
                        placeholder="Digite a descrição do chamado"
                        rows="4"></textarea>
                </div>
                <button type="submit" class="btn btn-primary" disabled="@carregando">
                    @if (carregando)
                    {
                        <span class="spinner-border spinner-border-sm me-2"></span>
                        <span>Processando...</span>
                    }
                    else
                    {
                        <span>✓ Abrir Chamado</span>
                    }
                </button>
                @if (!string.IsNullOrEmpty(mensagem))
                {
                    <div class="alert alert-success mt-3 mb-0">@mensagem</div>
                }
            </form>
        </div>
    </div>

    <!-- Seção de Lista -->
    <div class="card shadow-sm">
        <div class="card-header bg-secondary text-white">
            <h5 class="mb-0">📋 Chamados (@chamados.Count)</h5>
        </div>
        <div class="card-body">
            @if (carregandoLista)
            {
                <div class="text-center">
                    <div class="spinner-border" role="status">
                        <span class="visually-hidden">Carregando...</span>
                    </div>
                </div>
            }
            else if (!chamados.Any())
            {
                <div class="alert alert-info">
                    Nenhum chamado encontrado. Crie um novo chamado para começar!
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead class="table-light">
                            <tr>
                                <th>Título</th>
                                <th>Descrição</th>
                                <th>Status</th>
                                <th>Ações</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var c in chamados)
                            {
                                <tr>
                                    <td>
                                        <strong>@c.Titulo</strong>
                                    </td>
                                    <td>
                                        @if (!string.IsNullOrEmpty(c.Descricao))
                                        {
                                            <span>@c.Descricao.Substring(0, Math.Min(50, c.Descricao.Length))@(c.Descricao.Length > 50 ? "..." : "")</span>
                                        }
                                        else
                                        {
                                            <em class="text-muted">Sem descrição</em>
                                        }
                                    </td>
                                    <td>
                                        <span class="badge @GetStatusBadgeClass(c.Status.ToString())">
                                            @c.Status
                                        </span>
                                    </td>
                                    <td>
                                        <button class="btn btn-sm btn-outline-danger" @onclick="() => Deletar(c.Id)">
                                            🗑️ Deletar
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>

@code {
    List<Chamado> chamados = new();
    Chamado novo = new();
    bool carregando = false;
    bool carregandoLista = true;
    string mensagem = "";

    protected override async Task OnInitializedAsync()
    {
        await CarregarChamados();
    }

    private async Task CarregarChamados()
    {
        try
        {
            carregandoLista = true;
            chamados = await Http.GetFromJsonAsync<List<Chamado>>("api/chamados") ?? new();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Erro ao carregar chamados: {ex.Message}");
            chamados = new();
        }
        finally
        {
            carregandoLista = false;
        }
    }

    async Task Criar()
    {
        if (string.IsNullOrWhiteSpace(novo.Titulo))
        {
            mensagem = "O título é obrigatório!";
            return;
        }

        try
        {
            carregando = true;
            mensagem = "";
            await Http.PostAsJsonAsync("api/chamados", novo);
            novo = new();
            mensagem = "Chamado criado com sucesso!";
            await CarregarChamados();
        }
        catch (Exception ex)
        {
            mensagem = $"Erro ao criar chamado: {ex.Message}";
        }
        finally
        {
            carregando = false;
        }
    }

    async Task Deletar(int id)
    {
        if (!await ConfirmarDelecao())
            return;

        try
        {
            await Http.DeleteAsync($"api/chamados/{id}");
            await CarregarChamados();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Erro ao deletar chamado: {ex.Message}");
        }
    }

    private async Task<bool> ConfirmarDelecao()
    {
        return await JS.InvokeAsync<bool>("confirm", "Tem certeza que deseja deletar este chamado?");
    }

    private string GetStatusBadgeClass(string status) => status switch
    {
        "Aberto" => "bg-success",
        "Em Progresso" => "bg-warning text-dark",
        "Fechado" => "bg-secondary",
        _ => "bg-info"
    };
}